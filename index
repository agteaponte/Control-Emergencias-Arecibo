/* ─── CÁLCULO DE CRITICIDAD ──────────────────────────────────────────────── */
function calcCriticidad() {
  const nivel = STATE.nivelActivacion || 1;

  // ── Evaluar todos los cuarteles ───────────────────────────────────────
  const vals = Object.values(cuartelesData);

  const cqExtremo = vals.some(d =>
    d.generador === 'inoperable'
  );
  const cqCritico = !cqExtremo && vals.some(d =>
    d.generador === 'dano_parcial' ||
    (d.fuel != null && d.fuel <= 20) ||
    d.cisterna === 'critica'
  );
  const cqAlerta = !cqExtremo && !cqCritico && vals.some(d =>
    (d.fuel != null && d.fuel > 20 && d.fuel <= 40) ||
    d.cisterna === 'media' ||
    d.aguaPotable === 'no'
  );

  // ── Refugios ─────────────────────────────────────────────────────────
  const refCritico = refugios.some(r =>
    r.generador === 'fallo' || r.cisterna === 'critica' || (r.fuel != null && r.fuel <= 20));
  const refAlerta  = refugios.some(r =>
    r.cisterna === 'media' || (r.fuel != null && r.fuel > 20 && r.fuel <= 40));

  // ── Raciones ─────────────────────────────────────────────────────────
  const foodCritico = [STATE.foodArecibo, STATE.foodFlorida, STATE.foodMorovis].some(f => f === 'insuficiente');
  const foodAlerta  = [STATE.foodArecibo, STATE.foodFlorida, STATE.foodMorovis].some(f => f === 'bajo');

  // ── Escalamiento ─────────────────────────────────────────────────────
  const esExtremo =
    cqExtremo ||
    STATE.facilidad === 'inoperable' ||
    (STATE.radio === 'fallo' && STATE.satelital === 'no_disponible') ||
    nivel >= 5;

  const esCritico = !esExtremo && (
    cqCritico || foodCritico || STATE.radio === 'fallo' || refCritico || nivel >= 4
  );

  const esAlerta = !esExtremo && !esCritico && (
    cqAlerta || STATE.facilidad === 'dano_parcial' || foodAlerta ||
    STATE.radio === 'sin_bateria' || STATE.celular === 'sin_senal' ||
    refAlerta || nivel >= 3
  );

  let crit, lbl, desc;
  if      (esExtremo) { crit = 'EXTREMO'; lbl = 'EXTREMO'; desc = 'NOTIFICAR CDTE. ÁREA\nDE INMEDIATO'; }
  else if (esCritico) { crit = 'CRITICO'; lbl = 'CRÍTICO'; desc = 'Notificar coordinador\nde zona de inmediato'; }
  else if (esAlerta)  { crit = 'ALERTA';  lbl = 'ALERTA';  desc = 'Monitorear —\nRecursos bajo mínimo'; }
  else                { crit = 'NORMAL';  lbl = 'NORMAL';  desc = 'Situación estable'; }

  document.getElementById('crit-badge').className = 'crit-badge crit-' + crit;
  document.getElementById('crit-label').textContent = lbl;
  document.getElementById('crit-desc').textContent  = desc;
  document.getElementById('crit-dot').className = 'crit-dot' + (crit !== 'NORMAL' ? ' pulse' : '');
  return crit;
}

/* ─── VALIDACIÓN (FIX C-2: corregido STATE.food; FIX validación whitelist) ─ */
function sanitizarTexto(str, maxLen) {
  return String(str || '').trim().substring(0, maxLen);
}

function validar() {
  const op  = sanitizarTexto(document.getElementById('operador').value, MAX_OPERADOR);
  const dep = document.getElementById('dependencia').value;

  if (!op)  { toast('Ingrese placa / nombre del operador', 'warn'); return null; }
  if (!dep) { toast('Seleccione la dependencia', 'warn'); return null; }
  if (!STATE.nivelActivacion) { toast('Seleccione nivel de activación', 'warn'); return null; }
  if (!STATE.turno)           { toast('Seleccione el turno en curso', 'warn'); return null; }
  if (!STATE.facilidad)       { toast('Indique el estado de la facilidad', 'warn'); return null; }
  if (!STATE.radio)           { toast('Indique el estado del radio 800 MHz', 'warn'); return null; }

  // Verificar que al menos el cuartel propio tenga datos
  const [dependencia, zona] = dep.split('|');
  const miCuartel = CUARTELES.find(c =>
    c.nombre.toLowerCase().includes(dependencia.toLowerCase().split(' ')[0])
  );
  if (miCuartel) {
    const d = cuartelesData[miCuartel.id];
    if (!d.generador) { toast(`Indique el estado del generador de ${miCuartel.nombre}`, 'warn'); return null; }
    if (d.fuel == null || isNaN(d.fuel)) { toast(`Ingrese el combustible de ${miCuartel.nombre}`, 'warn'); return null; }
    if (!d.cisterna)  { toast(`Indique el estado de la cisterna de ${miCuartel.nombre}`, 'warn'); return null; }
  }

  // Whitelist validation en STATE
  for (const [k, allowed] of Object.entries(ALLOWED)) {
    const stateKeys = k === 'food'
      ? ['foodArecibo','foodFlorida','foodMorovis']
      : [k];
    for (const sk of stateKeys) {
      if (STATE[sk] && !allowed.includes(STATE[sk])) { STATE[sk] = null; }
    }
  }

  // Serializar cuartelesData — solo cuarteles con al menos un campo lleno
  const cuartelesReporte = CUARTELES
    .filter(c => {
      const d = cuartelesData[c.id];
      return d.generador || d.fuel != null || d.cisterna || d.aguaPotable;
    })
    .map(c => {
      const d = cuartelesData[c.id];
      return {
        id:          c.id,
        nombre:      c.nombre,
        zona:        c.zona,
        generador:   ALLOWED.generador.includes(d.generador)     ? d.generador    : null,
        fuel:        (d.fuel >= 0 && d.fuel <= 100)               ? d.fuel         : null,
        cisterna:    ALLOWED.cisterna.includes(d.cisterna)        ? d.cisterna     : null,
        agua_potable:ALLOWED.aguaPotable.includes(d.aguaPotable)  ? d.aguaPotable  : null,
      };
    });

  return {
    operador:          op,
    dependencia:       sanitizarTexto(dependencia, 40),
    zona:              sanitizarTexto(zona, 30),
    nivel_activacion:  STATE.nivelActivacion,
    turno:             STATE.turno,
    personal_servicio: Math.min(9999, Math.max(0, parseInt(document.getElementById('personal').value) || 0)) || null,
    vehiculos_op:      Math.min(999,  Math.max(0, parseInt(document.getElementById('vehiculos').value) || 0)) || null,
    estado_facilidad:  STATE.facilidad,
    cuarteles:         cuartelesReporte,
    refugios:          refugios
      .filter(r => r.nombre || r.generador || r.cisterna)
      .map(r => ({
        nombre:     sanitizarTexto(r.nombre, MAX_REF_NOMBRE),
        generador:  ALLOWED.generador.includes(r.generador) ? r.generador : null,
        cisterna:   ALLOWED.cisterna.includes(r.cisterna)   ? r.cisterna  : null,
        fuel:       (r.fuel != null && r.fuel >= 0 && r.fuel <= 100) ? r.fuel : null,
        capacidad:  (r.capacidad != null && r.capacidad >= 0) ? Math.min(9999, r.capacidad) : null,
      })),
    food_arecibo:      STATE.foodArecibo,
    food_florida:      STATE.foodFlorida,
    food_morovis:      STATE.foodMorovis,
    radio_800:         STATE.radio,
    satelital:         STATE.satelital,
    celular:           STATE.celular,
    notas:             sanitizarTexto(document.getElementById('notas').value, MAX_NOTAS),
    criticidad:        calcCriticidad(),
    fecha:             new Date().toISOString(),
    app_version:       '2.2',
  };
}

/* ─── ALMACENAMIENTO LOCAL (FIX A-3: límite de tamaño) ─────────────────── */
const MAX_LOCAL_REPORTS = 50;

function getPend() {
  try { return JSON.parse(localStorage.getItem(L_KEY)) || []; }
  catch { return []; }
}

function setPend(arr) {
  try {
    // Mantener solo los últimos MAX_LOCAL_REPORTS para evitar overflow
    const trimmed = arr.slice(-MAX_LOCAL_REPORTS);
    localStorage.setItem(L_KEY, JSON.stringify(trimmed));
  } catch(e) {
    // localStorage lleno — eliminar el reporte más antiguo y reintentar
    const arr2 = getPend().slice(1);
    try { localStorage.setItem(L_KEY, JSON.stringify(arr2)); } catch {}
    toast('⚠ Almacenamiento local casi lleno. Sincronice cuando tenga conexión.', 'warn');
  }
}

function savePend(r) {
  const p = getPend();
  r._lid  = 'l_' + Date.now();
  p.push(r);
  setPend(p);
  // Agregar al caché inmediatamente para que esté disponible al imprimir
  if (!reportesCache.find(c => c._lid === r._lid)) {
    reportesCache = [{ ...r, _synced: false }, ...reportesCache].slice(0, MAX_H);
  }
}

/* ─── SINCRONIZACIÓN (FIX A-1: guard de concurrencia) ────────────────────── */
async function sincronizarPendientes() {
  if (!db || isSyncing) return;
  const pend = getPend();
  if (!pend.length) return;

  isSyncing = true;
  showConn('syncing', `Sincronizando ${pend.length} reporte(s)...`);

  const ok = [], fail = [];
  for (const r of pend) {
    try {
      const { _lid, ...data } = r;
      data.sync_ts = new Date().toISOString();
      await addDoc(collection(db, COL), data);
      ok.push(_lid);
    } catch { fail.push(r); }
  }

  setPend(fail);
  isSyncing = false;

  if (ok.length)   { showConn('ok', `${ok.length} reporte(s) sincronizado(s)`, true); renderHistorial(); }
  if (fail.length) showConn('offline', `${fail.length} reporte(s) pendientes.`);
}

/* ─── ENVIAR (FIX A-2: rate limiting) ────────────────────────────────────── */
const btnSubmit = document.getElementById('btn-submit');

btnSubmit.addEventListener('click', async () => {
  // Rate limiting
  const now = Date.now();
  if (now - lastSubmitTs < SUBMIT_COOLDOWN_MS) {
    const seg = Math.ceil((SUBMIT_COOLDOWN_MS - (now - lastSubmitTs)) / 1000);
    toast(`Espere ${seg}s antes del próximo envío`, 'warn');
    return;
  }

  const rep = validar();
  if (!rep) return;

  btnSubmit.disabled = true;
  btnSubmit.classList.add('loading');
  lastSubmitTs = Date.now();

  // Guardar operador (solo si tiene formato válido)
  if (/^[\w\s\-\.#áéíóúÁÉÍÓÚñÑ]+$/.test(rep.operador)) {
    localStorage.setItem(L_OP, rep.operador);
  }
  localStorage.setItem(L_DEP, document.getElementById('dependencia').value);
  localStorage.setItem(L_TS,  Date.now().toString());

  const online = await checkRealConnectivity();

  if (db && online) {
    try {
      await addDoc(collection(db, COL), rep);
      // Añadir al caché como sincronizado
      reportesCache = [{ ...rep, _synced: true }, ...reportesCache].slice(0, MAX_H);
      toast('✓ Reporte transmitido y sincronizado', 'ok');
      showConn('ok', '✓ Reporte sincronizado con Firebase', true);
    } catch(e) {
      savePend(rep);
      toast('⚠ Error de red — Guardado localmente', 'warn');
    }
  } else {
    savePend(rep);
    toast('⚠ Sin conexión — Guardado localmente', 'warn');
  }

  btnSubmit.disabled = false;
  btnSubmit.classList.remove('loading');

  // Reset campos volátiles
  document.getElementById('personal').value  = '';
  document.getElementById('vehiculos').value = '';
  document.getElementById('notas').value     = '';

  const keys = ['facilidad','foodArecibo','foodFlorida','foodMorovis','radio','satelital','celular'];
  keys.forEach(k => STATE[k] = null);
  STATE.nivelActivacion = null;
  STATE.turno           = null;

  // Limpiar cuartelesData
  CUARTELES.forEach(c => {
    cuartelesData[c.id] = { generador: null, fuel: null, cisterna: null, aguaPotable: null };
  });
  renderCuarteles();

  refugios = [];
  renderRefugios();

  document.querySelectorAll('.btn-opt').forEach(b =>
    b.classList.remove('sel-green','sel-amber','sel-red','sel-blue'));
  document.querySelectorAll('.nivel-btn').forEach(b => b.className = 'nivel-btn');

  calcCriticidad();
  actualizarTimer();
  renderHistorial();
});

