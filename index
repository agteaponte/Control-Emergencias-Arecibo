}
.cq-btn:hover{border-color:var(--border2);color:var(--text);}
.cq-btn.sel-g{background:var(--green-dim);border-color:var(--green);color:var(--green);}
.cq-btn.sel-a{background:var(--amber-dim);border-color:var(--amber);color:var(--amber);}
.cq-btn.sel-r{background:var(--red-dim);  border-color:var(--red);  color:var(--red);}

.cq-fuel-wrap{display:flex;align-items:center;gap:7px;}
.cq-fuel-inp{
  width:60px;padding:7px 8px;
  background:var(--surface2);border:1px solid var(--border);
  border-radius:4px;color:var(--text-bright);
  font-family:var(--mono);font-size:13px;text-align:center;
  -webkit-appearance:none;flex-shrink:0;
}
.cq-fuel-inp:focus{outline:none;border-color:var(--blue);}
.cq-fuel-bar{flex:1;height:5px;background:var(--surface2);border-radius:3px;overflow:hidden;}
.cq-fuel-fill{height:100%;width:0%;border-radius:3px;transition:width .3s,background .3s;}

/* zona group spacing */
.cq-zone-group{margin-bottom:14px;}
.cq-zone-group:last-child{margin-bottom:0;}


.btn-add-refugio{
  width:100%;padding:11px;margin-top:10px;
  background:transparent;border:1px dashed var(--border2);
  border-radius:var(--r);color:var(--blue);
  font-family:var(--head);font-size:12px;font-weight:600;
  letter-spacing:.1em;cursor:pointer;
  transition:all var(--tr);
}
.btn-add-refugio:hover{background:var(--blue-glow);border-color:var(--blue);}

.refugio-card{
  background:var(--bg2);border:1px solid var(--border2);
  border-radius:var(--r);padding:13px;margin-bottom:10px;
  position:relative;
  animation:fadeIn .25s ease;
}
.refugio-header{
  display:flex;align-items:center;gap:8px;margin-bottom:12px;
}
.refugio-num{
  font-family:var(--head);font-size:10px;font-weight:700;
  letter-spacing:.12em;color:var(--amber);
  background:var(--amber-dim);border:1px solid var(--amber-dim);
  border-radius:3px;padding:2px 7px;text-transform:uppercase;
}
.refugio-name-input{
  flex:1;padding:7px 10px;
  background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--r);color:var(--text-bright);
  font-family:var(--body);font-size:14px;
}
.refugio-name-input:focus{outline:none;border-color:var(--blue);}
.btn-del-refugio{
  background:none;border:1px solid var(--red-dim);color:var(--red);
  border-radius:4px;padding:5px 9px;cursor:pointer;font-size:13px;
  transition:all var(--tr);flex-shrink:0;
}
.btn-del-refugio:hover{background:var(--red-dim);}
.refugio-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.refugio-label{
  font-family:var(--head);font-size:10px;font-weight:600;
  letter-spacing:.09em;text-transform:uppercase;
  color:var(--text-dim);margin-bottom:5px;display:block;
}
.refugio-fuel-row{
  display:flex;align-items:center;gap:8px;
}
.refugio-fuel-input{
  width:80px;padding:7px 10px;
  background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--r);color:var(--text-bright);
  font-family:var(--mono);font-size:14px;
  -webkit-appearance:none;
}
.refugio-fuel-input:focus{outline:none;border-color:var(--blue);}
.refugio-fuel-track{
  flex:1;height:5px;background:var(--surface2);
  border:1px solid var(--border);border-radius:3px;overflow:hidden;
}
.refugio-fuel-fill{height:100%;width:0%;border-radius:3px;transition:width .3s,background .3s;}

/* ═══════════════════════════════════════════════════
   RACIONES POR ZONA
═══════════════════════════════════════════════════ */
.zona-racion-row{
  display:flex;align-items:center;gap:10px;
  padding:10px 0;border-bottom:1px solid var(--border);
}
.zona-racion-row:last-child{border-bottom:none;}
.zona-racion-lbl{
  display:flex;align-items:center;gap:7px;
