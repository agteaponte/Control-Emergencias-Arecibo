const connIcon = document.getElementById('conn-icon');

function showConn(tipo, msg, auto = false) {
  connBar.className    = 'conn-bar ' + tipo;
  connIcon.textContent = tipo === 'offline' ? '⚠' : tipo === 'syncing' ? '↻' : '✓';
  connMsg.textContent  = msg;
  if (auto) setTimeout(() => { connBar.className = 'conn-bar'; }, 4000);
}

async function checkRealConnectivity() {
  if (!navigator.onLine) return false;
  try {
    // Ping a un endpoint conocido y confiable con timeout corto
    const ctrl = new AbortController();
    setTimeout(() => ctrl.abort(), 4000);
    await fetch('https://www.gstatic.com/generate_204', {
      method: 'HEAD', mode: 'no-cors', cache: 'no-store', signal: ctrl.signal
    });
    return true;
  } catch {
    return false;
  }
}

async function onlineCheck() {
  const online = await checkRealConnectivity();
  if (online) {
    connBar.className = 'conn-bar';
    sincronizarPendientes();
  } else {
    showConn('offline', 'Sin conexión · Reportes guardados localmente');
  }
}
