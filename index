function fmtFecha(iso) {
  return new Date(iso).toLocaleString('es-PR', {
    day:'2-digit', month:'2-digit', year:'2-digit',
    hour:'2-digit', minute:'2-digit', hour12:false
  });
}

// Genera tags usando textContent — sin innerHTML con datos
function makeTag(texto, clase) {
  const s = document.createElement('span');
  s.className   = 'tag ' + (clase || '');
  s.textContent = texto;
  return s;
}

function buildReportItem(r) {
  const item = document.createElement('div');
  item.className = 'rpt-item';

  const dot = document.createElement('div');
  dot.className = 'rpt-dot ' + (r._synced ? 'synced' : 'pending');

  const body = document.createElement('div');
  body.className = 'rpt-body';

  // Top row
  const top  = document.createElement('div');
  top.className = 'rpt-top';
  const zone = document.createElement('div');
  zone.className = 'rpt-zone';
  zone.textContent = (r.dependencia || '—');
  const zoneSub = document.createElement('span');
  zoneSub.style.cssText = 'color:var(--text-dim);font-size:11px;margin-left:5px;';
  zoneSub.textContent = r.zona || '';
  zone.appendChild(zoneSub);
  const ts = document.createElement('div');
  ts.className   = 'rpt-ts';
  ts.textContent = fmtFecha(r.fecha);
  top.append(zone, ts);

  // Operador
  const op = document.createElement('div');
  op.className   = 'rpt-op';
  op.textContent = `👤 ${r.operador || '—'} · Turno ${r.turno || '—'}`;

  // Tags
  const tags = document.createElement('div');
  tags.className = 'tags';

  const critMap  = { EXTREMO:'r', CRITICO:'r', ALERTA:'a', NORMAL:'g' };
  const fuelV    = r.fuel;
  const radioMap = { operativo:'g', sin_bateria:'a', fallo:'r' };
  const radioLbl = { operativo:'Radio OK', sin_bateria:'Radio Sin Bat.', fallo:'Radio FALLO' };
  const facMap   = { operable:'g', dano_parcial:'a', inoperable:'r' };
  const facLbl   = { operable:'Operable', dano_parcial:'Daño Parcial', inoperable:'INOPERABLE' };

  if (r.nivel_activacion) tags.appendChild(makeTag(`Nv ${r.nivel_activacion}`, r.nivel_activacion >= 4 ? 'r' : r.nivel_activacion >= 3 ? 'a' : r.nivel_activacion >= 2 ? 'b' : 'g'));
  if (r.criticidad)       tags.appendChild(makeTag(r.criticidad, critMap[r.criticidad] || ''));
  if (r.estado_facilidad) tags.appendChild(makeTag(facLbl[r.estado_facilidad] || r.estado_facilidad, facMap[r.estado_facilidad] || ''));
  if (fuelV != null)      tags.appendChild(makeTag(`⛽ ${fuelV}%`, fuelV <= 20 ? 'r' : fuelV <= 40 ? 'a' : 'g'));
  if (r.radio_800)        tags.appendChild(makeTag(radioLbl[r.radio_800] || r.radio_800, radioMap[r.radio_800] || ''));
  if (r.personal_servicio != null) tags.appendChild(makeTag(`👮 ${r.personal_servicio}`, ''));
  if (!r._synced)         tags.appendChild(makeTag('Pendiente', 'a'));

  body.append(top, op, tags);

  // Notas (textContent — seguro)
  if (r.notas) {
    const notaEl = document.createElement('div');
    notaEl.style.cssText = 'margin-top:6px;font-size:11px;color:var(--text-dim);line-height:1.4;';
    notaEl.textContent   = '📝 ' + r.notas.substring(0, 120) + (r.notas.length > 120 ? '…' : '');
    body.appendChild(notaEl);
  }

  item.append(dot, body);
  return item;
}

async function renderHistorial() {
  const list   = document.getElementById('report-list');
  const sb     = document.getElementById('sync-banner');
  const pend   = getPend();
  const remote = [];

  if (db && navigator.onLine) {
    try {
      const snap = await getDocs(query(collection(db, COL), orderBy('fecha','desc'), limit(MAX_H)));
      snap.forEach(d => remote.push({ ...d.data(), _synced: true }));
    } catch {}
  }

  // Banner pendientes
  if (pend.length) {
    sb.style.display = 'block';
    sb.innerHTML = `<div class="sync-band">
      <span>⚠ ${parseInt(pend.length)} reporte(s) pendiente(s)</span>
      ${navigator.onLine && db ? '<button class="btn-sync" id="btn-sync-manual">Sincronizar</button>' : ''}
    </div>`;
    document.getElementById('btn-sync-manual')?.addEventListener('click', sincronizarPendientes);
  } else {
    sb.style.display = 'none';
    sb.innerHTML = '';
  }

  const todos = [
    ...pend.map(r => ({ ...r, _synced: false })),
    ...remote
  ].sort((a, b) => new Date(b.fecha) - new Date(a.fecha)).slice(0, MAX_H);

  // ── Actualizar caché para impresión ──────────────────────────────────
  reportesCache = todos;

  list.innerHTML = '';
  if (!todos.length) {
    const empty = document.createElement('div');
    empty.className   = 'empty';
    empty.textContent = 'SIN REPORTES REGISTRADOS';
    list.appendChild(empty);
    return;
  }
  todos.forEach(r => list.appendChild(buildReportItem(r)));
}

