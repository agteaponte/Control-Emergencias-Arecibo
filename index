  const diff = Date.now() - last;
  const sixH = 6 * 3600 * 1000;
  const el   = document.getElementById('reporte-timer');
  const msg  = document.getElementById('timer-msg');
  const icon = document.getElementById('timer-icon');
  if (diff >= sixH) {
    el.style.display = 'flex'; el.classList.add('urgente');
    icon.textContent = '🔴';
    msg.textContent  = '⚠ REPORTE VENCIDO — Más de 6 horas sin reportar · Plan Base Sec. V-E';
  } else {
    const resta = Math.ceil((sixH - diff) / 60000);
    el.style.display = 'flex'; el.classList.remove('urgente');
    icon.textContent = '⏱';
    msg.textContent  = `Próximo reporte en ${resta} min · Reporte c/6h · Plan Base Sec. V-E`;
  }
}
