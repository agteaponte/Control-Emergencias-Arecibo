}
.zona-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}


.empty{
  text-align:center;padding:28px 0;
  font-family:var(--mono);font-size:11px;
  color:var(--text-dim);letter-spacing:.1em;
