/* ─── REFUGIOS DINÁMICOS ─────────────────────────────────────────────────── */
/* ─── BARRA DE COMBUSTIBLE ───────────────────────────────────────────────── */
document.getElementById('fuel').addEventListener('input', function() {
  const v   = Math.min(100, Math.max(0, parseInt(this.value) || 0));
  const fill = document.getElementById('fuel-fill');
  const lblL = document.getElementById('fuel-lbl-l');
  fill.style.width = v + '%';
  lblL.textContent = v + '%';
  if (v <= 20)      { fill.style.background = 'var(--red)';   lblL.style.color = 'var(--red)'; }
  else if (v <= 40) { fill.style.background = 'var(--amber)'; lblL.style.color = 'var(--amber)'; }
  else              { fill.style.background = 'var(--green)';  lblL.style.color = 'var(--green)'; }
  calcCriticidad();
});

/* ─── CÁLCULO DE CRITICIDAD ──────────────────────────────────────────────── */
function calcCriticidad() {
  const fuel  = parseInt(document.getElementById('fuel').value) || 101;
  const nivel = STATE.nivelActivacion || 1;

  // Revisar refugios críticos
  const refCritico = refugios.some(r =>
    r.generador === 'fallo' || r.cisterna === 'critica' || (r.fuel != null && r.fuel <= 20));
  const refAlerta  = refugios.some(r =>
    r.cisterna === 'media' || (r.fuel != null && r.fuel > 20 && r.fuel <= 40));

  // Raciones críticas
  const foodCritico = [STATE.foodArecibo, STATE.foodFlorida, STATE.foodMorovis]
    .some(f => f === 'insuficiente');
  const foodAlerta  = [STATE.foodArecibo, STATE.foodFlorida, STATE.foodMorovis]
    .some(f => f === 'bajo');

  const esExtremo =
    STATE.facilidad === 'inoperable' ||
    (STATE.generador === 'fallo' && STATE.radio === 'fallo') ||
    (STATE.radio === 'fallo' && STATE.satelital === 'no_disponible') ||
    nivel >= 5;

  const esCritico = !esExtremo && (
    fuel <= 20 ||
    STATE.generador === 'fallo' ||
    STATE.cisterna  === 'critica' ||
    foodCritico ||
    STATE.radio     === 'fallo' ||
    refCritico ||
    nivel >= 4
  );

  const esAlerta = !esExtremo && !esCritico && (
    (fuel > 20 && fuel <= 40) ||
    STATE.facilidad === 'dano_parcial' ||
    STATE.cisterna  === 'media' ||
    foodAlerta ||
    STATE.radio     === 'sin_bateria' ||
    STATE.aguaPotable === 'no' ||
    STATE.celular   === 'sin_senal' ||
    refAlerta ||
    nivel >= 3
  );

  let crit, lbl, desc;
  if (esExtremo) {
    crit = 'EXTREMO'; lbl = 'EXTREMO';
    desc = 'NOTIFICAR CDTE. ÁREA\nDE INMEDIATO';
  } else if (esCritico) {
    crit = 'CRITICO'; lbl = 'CRÍTICO';
    desc = 'Notificar coordinador\nde zona de inmediato';
  } else if (esAlerta) {
    crit = 'ALERTA'; lbl = 'ALERTA';
    desc = 'Monitorear —\nRecursos bajo mínimo';
  } else {
    crit = 'NORMAL'; lbl = 'NORMAL';
    desc = 'Situación estable';
  }

  const badge = document.getElementById('crit-badge');
  const dot   = document.getElementById('crit-dot');
  badge.className = 'crit-badge crit-' + crit;
  document.getElementById('crit-label').textContent = lbl;
  document.getElementById('crit-desc').textContent  = desc;
  dot.className = 'crit-dot' + (crit !== 'NORMAL' ? ' pulse' : '');
  return crit;
}

/* ─── VALIDACIÓN ─────────────────────────────────────────────────────────── */
function validar() {
  const op  = document.getElementById('operador').value.trim();
  const dep = document.getElementById('dependencia').value;
  const fuel = document.getElementById('fuel').value;

  if (!op)               { toast('Ingrese placa / nombre del operador', 'warn'); return null; }
  if (!dep)              { toast('Seleccione la dependencia', 'warn'); return null; }
  if (!STATE.nivelActivacion) { toast('Seleccione nivel de activación', 'warn'); return null; }
  if (!STATE.turno)      { toast('Seleccione el turno en curso', 'warn'); return null; }
  if (!STATE.facilidad)  { toast('Indique el estado de la facilidad', 'warn'); return null; }
  if (!STATE.generador)  { toast('Indique el estado del generador', 'warn'); return null; }
  if (fuel === '' || isNaN(parseInt(fuel))) { toast('Ingrese el % de combustible', 'warn'); return null; }
  if (!STATE.cisterna)   { toast('Indique el estado de la cisterna', 'warn'); return null; }
  if (!STATE.radio)      { toast('Indique el estado del radio 800 MHz', 'warn'); return null; }

  const [dependencia, zona] = dep.split('|');

  return {
    operador:          op,
    dependencia,
    zona:              zona || '',
    nivel_activacion:  STATE.nivelActivacion,
    turno:             STATE.turno,
    personal_servicio: parseInt(document.getElementById('personal').value) || null,
    vehiculos_op:      parseInt(document.getElementById('vehiculos').value) || null,
    estado_facilidad:  STATE.facilidad,
    generador:         STATE.generador,
    fuel:              parseInt(fuel),
    cisterna:          STATE.cisterna,
    agua_potable:      STATE.aguaPotable,
    food_arecibo:      STATE.foodArecibo,
    food_florida:      STATE.foodFlorida,
    food_morovis:      STATE.foodMorovis,
    refugios:          refugios.filter(r => r.nombre || r.generador || r.cisterna),
    radio_800:         STATE.radio,
    satelital:         STATE.satelital,
    celular:           STATE.celular,
    notas:             document.getElementById('notas').value.trim(),
    criticidad:        calcCriticidad(),
    fecha:             new Date().toISOString(),
  };
}

/* ─── ALMACENAMIENTO LOCAL ───────────────────────────────────────────────── */
function getPend()      { try { return JSON.parse(localStorage.getItem(L_KEY)) || []; } catch { return []; } }
function setPend(arr)   { localStorage.setItem(L_KEY, JSON.stringify(arr)); }
function savePend(r)    { const p = getPend(); r._lid = 'l_' + Date.now(); p.push(r); setPend(p); }

/* ─── SINCRONIZACIÓN ─────────────────────────────────────────────────────── */
async function sincronizarPendientes() {
  if (!db) return;
  const pend = getPend();
  if (!pend.length) return;
  showConn('syncing', `Sincronizando ${pend.length} reporte(s)...`);
  const ok = [], fail = [];
  for (const r of pend) {
    try {
      const { _lid, ...data } = r;
      data.sync_ts = new Date().toISOString();
      await addDoc(collection(db, COL), data);
      ok.push(_lid);
    } catch { fail.push(r); }
  }
  setPend(fail);
  if (ok.length)   { showConn('ok', `${ok.length} reporte(s) sincronizado(s)`, true); renderHistorial(); }
  if (fail.length) showConn('offline', `${fail.length} reporte(s) pendientes.`);
}

/* ─── ENVIAR ─────────────────────────────────────────────────────────────── */
const btnSubmit = document.getElementById('btn-submit');
btnSubmit.addEventListener('click', async () => {
  const rep = validar();
  if (!rep) return;

  btnSubmit.disabled = true;
  btnSubmit.classList.add('loading');

  // Guardar operador para la próxima vez
  localStorage.setItem(L_OP,  rep.operador);
  localStorage.setItem(L_DEP, document.getElementById('dependencia').value);
  localStorage.setItem(L_TS,  Date.now().toString());

  if (db && navigator.onLine) {
    try {
      await addDoc(collection(db, COL), rep);
      toast('✓ Reporte transmitido y sincronizado', 'ok');
      showConn('ok', '✓ Reporte sincronizado con Firebase', true);
    } catch {
      savePend(rep);
      toast('⚠ Guardado localmente (error red)', 'warn');
    }
  } else {
    savePend(rep);
    toast('⚠ Sin conexión — Guardado localmente', 'warn');
  }

  btnSubmit.disabled = false;
  btnSubmit.classList.remove('loading');

  // Resetear solo campos volátiles; conservar operador y dependencia
  document.getElementById('fuel').value  = '';
  document.getElementById('personal').value = '';
  document.getElementById('vehiculos').value = '';
  document.getElementById('notas').value = '';
  document.getElementById('fuel-fill').style.width = '0%';
  document.getElementById('fuel-lbl-l').textContent = '0%';

  // Resetear estados y botones visuales
  const keys = ['facilidad','generador','cisterna','aguaPotable','foodArecibo','foodFlorida','foodMorovis','radio','satelital','celular'];
  keys.forEach(k => STATE[k] = null);
  STATE.nivelActivacion = null;
  STATE.turno = null;
  refugios = [];
  renderRefugios();
  document.querySelectorAll('.btn-opt').forEach(b => b.classList.remove('sel-green','sel-amber','sel-red','sel-blue'));
  document.querySelectorAll('.nivel-btn').forEach(b => b.className = 'nivel-btn');

  calcCriticidad();
  actualizarTimer();
  renderHistorial();
});

/* ─── HISTORIAL ──────────────────────────────────────────────────────────── */


function critTag(v) {
  const map = {
    EXTREMO: 'r', CRITICO: 'r', ALERTA: 'a', NORMAL: 'g'
  };
  return `<span class="tag ${map[v]||''}">${v||'N/D'}</span>`;
}

function fuelTag(v) {
  if (v == null) return '';
  const cls = v <= 20 ? 'r' : v <= 40 ? 'a' : 'g';
  return `<span class="tag ${cls}">⛽ ${v}%</span>`;
}

function radioTag(v) {
  const map = {operativo:'g', sin_bateria:'a', fallo:'r'};
  const lbl = {operativo:'Radio OK', sin_bateria:'Radio Sin Bat.', fallo:'Radio FALLO'};
  return v ? `<span class="tag ${map[v]||''}">${lbl[v]||v}</span>` : '';
}

function facilTag(v) {
  const map = {operable:'g', dano_parcial:'a', inoperable:'r'};
  const lbl = {operable:'Operable', dano_parcial:'Daño Parcial', inoperable:'INOPERABLE'};
  return v ? `<span class="tag ${map[v]||''}">${lbl[v]||v}</span>` : '';
}

