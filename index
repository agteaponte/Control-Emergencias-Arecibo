  ]},
];

const PP_KEY = 'mando_pp_checks';
let ppState  = JSON.parse(localStorage.getItem(PP_KEY) || '{}');

function renderPP() {
  const el = document.getElementById('pp-list');
  let html = '';
  let idx  = 0;
  PP_ITEMS.forEach(sec => {
    html += `<div class="check-phase">${sec.fase}</div>`;
    sec.items.forEach(item => {
      const done = !!ppState[idx];
      html += `<div class="check-item">
        <div class="check-box ${done?'done':''}" data-i="${idx}" onclick="togglePP(${idx})"></div>
        <span style="color:${done?'var(--text-dim)':'var(--text)'};">${item}</span>
      </div>`;
      idx++;
    });
  });
  el.innerHTML = html;
}

window.togglePP = function(i) {
  ppState[i] = !ppState[i];
  localStorage.setItem(PP_KEY, JSON.stringify(ppState));
  renderPP();
};

window.resetPP = function() {
  ppState = {};
  localStorage.setItem(PP_KEY, JSON.stringify(ppState));
  renderPP();
};

renderPP();
