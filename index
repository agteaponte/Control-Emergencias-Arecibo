  const el     = document.getElementById('reporte-timer');
  const msg    = document.getElementById('timer-msg');
  const icon   = document.getElementById('timer-icon');

  if (diff >= sixH) {
    el.style.display = 'flex';
    el.classList.add('urgente');
    icon.textContent = '🔴';
    msg.textContent  = '⚠ REPORTE VENCIDO — Más de 6 horas sin reportar · Plan Base Sec. V-E';
  } else {
    const resta = Math.ceil((sixH - diff) / 60000);
    el.style.display = 'flex';
    el.classList.remove('urgente');
    icon.textContent = '⏱';
    msg.textContent  = `Próximo reporte en ${resta} min · Reporte c/6h · Plan Base Sec. V-E`;
  }
}
actualizarTimer();
setInterval(actualizarTimer, 30000);

/* ─── CONEXIÓN ───────────────────────────────────────────────────────────── */
const connBar = document.getElementById('conn-bar');
const connMsg = document.getElementById('conn-msg');
const connIcon= document.getElementById('conn-icon');

function showConn(tipo, msg, auto = false) {
  connBar.className = 'conn-bar ' + tipo;
  connIcon.textContent = tipo === 'offline' ? '⚠' : tipo === 'syncing' ? '↻' : '✓';
  connMsg.textContent  = msg;
  if (auto) setTimeout(() => { connBar.className = 'conn-bar'; }, 4000);
}

function onlineCheck() {
  if (navigator.onLine) {
    connBar.className = 'conn-bar';
    sincronizarPendientes();
  } else {
    showConn('offline', 'Sin conexión · Reportes guardados localmente');
  }
}
window.addEventListener('online',  onlineCheck);
window.addEventListener('offline', onlineCheck);
onlineCheck();

/* ─── TOAST ──────────────────────────────────────────────────────────────── */
let toastTimer;
function toast(msg, tipo = 'ok') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className   = 'show ' + tipo;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { el.className = ''; }, 3000);
}

/* ─── BOTONES TOGGLE ─────────────────────────────────────────────────────── */
function selBtn(groupId, val, colorKey) {
  // colorKey: 'G'=green, 'A'=amber, 'R'=red, 'B'=blue
  const colorMap = {
    G: 'sel-green', A: 'sel-amber', R: 'sel-red', B: 'sel-blue'
  };
  // Para grupos de 3 opciones, el color depende de la posición
  const group = document.getElementById(groupId);
  if (!group) return;
  group.querySelectorAll('.btn-opt').forEach(b => {
    b.classList.remove('sel-green','sel-amber','sel-red','sel-blue');
    if (b.dataset.val === val) {
      const cls = colorKey ? colorMap[colorKey] : getAutoColor(groupId, val);
      b.classList.add(cls);
    }
  });
}

function getAutoColor(groupId, val) {
  const redVals   = ['fallo','inoperable','critica','no','insuficiente','sin_senal','no_disponible'];
  const amberVals = ['dano_parcial','sin_bateria','media','bajo','limitada'];
  const greenVals = ['operativo','operable','llena','si','ok','operativa'];
  const blueVals  = ['A','B'];
  if (redVals.includes(val))   return 'sel-red';
  if (amberVals.includes(val)) return 'sel-amber';
  if (greenVals.includes(val)) return 'sel-green';
  if (blueVals.includes(val))  return 'sel-blue';
  return 'sel-blue';
}

function initBtnGroup(groupId, stateKey, cb) {
  const group = document.getElementById(groupId);
  if (!group) return;
  group.querySelectorAll('.btn-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      STATE[stateKey] = btn.dataset.val;
      group.querySelectorAll('.btn-opt').forEach(b =>
        b.classList.remove('sel-green','sel-amber','sel-red','sel-blue'));
      btn.classList.add(getAutoColor(groupId, btn.dataset.val));
      if (cb) cb();
      calcCriticidad();
    });
  });
}

