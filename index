/* ═══════════════════════════════════════════════════
   BOTÓN IMPRIMIR
═══════════════════════════════════════════════════ */
.btn-print{
  margin-left:auto;padding:5px 12px;
  background:transparent;border:1px solid var(--border2);
  border-radius:4px;color:var(--text-dim);
  font-family:var(--head);font-size:10px;font-weight:600;
  letter-spacing:.08em;cursor:pointer;
  transition:all var(--tr);white-space:nowrap;
}
.btn-print:hover{border-color:var(--blue);color:var(--blue);}

/* El área de impresión está oculta en pantalla */
#print-area{display:none;}

/* ═══════════════════════════════════════════════════
   ESTILOS DE IMPRESIÓN
═══════════════════════════════════════════════════ */
@media print{
  *{-webkit-print-color-adjust:exact;print-color-adjust:exact;}

  /* Ocultar toda la UI de la app */
  body{background:#fff!important;color:#000!important;font-family:Arial,sans-serif;font-size:10pt;margin:0;padding:0;}
  .hdr,.conn-bar,#reporte-timer,.wrap,.btn-submit,
  .contacts-toggle,.contacts-panel,.sync-band,.btn-print,
  #sync-banner,#toast{display:none!important;}

  /* Mostrar solo la zona de impresión */
  #print-area{display:block!important;}

  /* Encabezado */
  .print-header{display:flex!important;align-items:center;gap:14px;padding-bottom:10px;border-bottom:3px solid #003080;margin-bottom:16px;}
  .print-logo{width:65px;height:65px;object-fit:contain;border-radius:50%;}
  .print-title{font-size:14pt;font-weight:700;color:#003080;text-transform:uppercase;letter-spacing:.05em;line-height:1.2;}
  .print-sub{font-size:8pt;color:#555;margin-top:3px;}
  .print-ts{margin-left:auto;font-size:8pt;color:#555;text-align:right;line-height:1.7;}

  /* Tabla */
  .print-table{width:100%;border-collapse:collapse;font-size:8pt;}
  .print-table th{background:#003080!important;color:#fff!important;padding:7px 8px;text-align:left;font-size:7.5pt;letter-spacing:.06em;text-transform:uppercase;}
  .print-table td{padding:5px 8px;border-bottom:1px solid #ccc;vertical-align:top;line-height:1.4;}
  .print-table tr:nth-child(even) td{background:#f2f5fb!important;}
  .print-table tr{page-break-inside:avoid;}

  /* Estado criticidad */
  .pb-extremo{color:#7a0000;font-weight:700;}
  .pb-critico{color:#c0000a;font-weight:700;}
  .pb-alerta {color:#7a4a00;font-weight:700;}
  .pb-normal {color:#005a1f;}

  /* Estado cuarteles en impresión */
  .pb-inoperable{color:#c0000a;font-weight:700;}
  .pb-parcial   {color:#7a4a00;}
  .pb-operativo {color:#005a1f;}

  /* Tags de recursos */
  .print-tag{display:inline-block;padding:1px 5px;border-radius:2px;font-size:7pt;margin:1px;border:1px solid #ccc;}
  .print-tag.r{background:#fff0f0;border-color:#ffaaaa;color:#a00;}
  .print-tag.a{background:#fffbe6;border-color:#ffc;color:#7a4a00;}
  .print-tag.g{background:#f0fff4;border-color:#aaeebb;color:#006620;}

  /* Sección de cuarteles */
  .print-section-title{font-size:9pt;font-weight:700;color:#003080;letter-spacing:.08em;text-transform:uppercase;margin:12px 0 6px;padding-bottom:4px;border-bottom:1px solid #ccc;}
  .print-cq-table{width:100%;border-collapse:collapse;font-size:8pt;margin-bottom:10px;}
  .print-cq-table th{background:#e8eef8!important;color:#003080!important;padding:5px 7px;font-size:7.5pt;}
  .print-cq-table td{padding:4px 7px;border-bottom:1px solid #ddd;}

  /* Footer */
  .print-footer{margin-top:14px;padding-top:8px;border-top:1px solid #ccc;font-size:7pt;color:#999;display:flex;justify-content:space-between;}

  @page{margin:1.8cm 2cm;size:letter landscape;}
}

/* ═══════════════════════════════════════════════════
   TOAST NOTIFICATION
═══════════════════════════════════════════════════ */
#toast{
  position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);
  background:var(--surface2);border:1px solid var(--border2);
  border-radius:8px;padding:10px 18px;
  font-family:var(--mono);font-size:12px;color:var(--text-bright);
  white-space:nowrap;z-index:9998;
  transition:transform .3s ease,opacity .3s ease;opacity:0;
  pointer-events:none;
}
#toast.show{transform:translateX(-50%) translateY(0);opacity:1;}
#toast.ok{border-color:var(--green-dim);color:var(--green);}
#toast.warn{border-color:var(--amber-dim);color:var(--amber);}
#toast.err{border-color:var(--red-dim);color:var(--red);}

/* ═══════════════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════════════ */
@media(max-width:440px){
  .grid2{grid-template-columns:1fr;}
  .nivel-btn .lbl{display:none;}
  .nivel-btn .num{font-size:16px;}
  #hdr-turno{display:none;}
}
