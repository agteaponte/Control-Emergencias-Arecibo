}
.cq-status-dot.ok   {background:var(--green);}
.cq-status-dot.warn {background:var(--amber);}
.cq-status-dot.bad  {background:var(--red); animation:cpulse 1s infinite;}

.cq-fields{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
